# Neon Postgres
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# מנהל יחיד (אזור ניהול + סטודיו AI)
ADMIN_EMAIL=your-admin-username
ADMIN_PASSWORD=your-secure-password
JWT_SECRET=your-long-random-secret-at-least-32-chars

# Cloudinary (תמונות באתר + סטודיו AI)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Replicate (יצירת תמונות AI)
REPLICATE_API_TOKEN=r8_...

# Google Gemini (זיהוי תמונה + טקסט — אופציונלי)
GEMINI_API_KEY=

# כתובת הבסיס של האתר — ל-SEO (sitemap, robots, OpenGraph, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://yerushalmi-diamonds.co.il
